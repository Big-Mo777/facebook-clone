# ─── Configuration Frontend Next.js ──────────────────────────────────────────

# URL de l'API (maintenant les API Routes Next.js au lieu du backend Express)
NEXT_PUBLIC_API_URL=http://localhost:3000

# ─── Configuration Backend (MySQL) ────────────────────────────────────────────

# Base de données MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=facebook_clone

# ─── Configuration JWT ────────────────────────────────────────────────────────

# Secret pour signer les JWT (générer une clé forte en production)
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# ─── Environnement ───────────────────────────────────────────────────────────

NODE_ENV=development